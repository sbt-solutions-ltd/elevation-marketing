# nuxt-og-image (bundled by @nuxtjs/seo) declares an optional peer on
# tailwindcss@^4, but this project uses Tailwind 3. The og-image feature is
# disabled in nuxt.config (ogImage: { enabled: false }), so the mismatch is
# inert — accept it instead of failing the install. Keeps `npm ci` working in CI.
legacy-peer-deps=true
